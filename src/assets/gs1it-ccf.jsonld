        "@language": "en",
        "@value": "Steel"
      },
      "skos:prefLabel": "METAL_STEEL",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-METAL_TIN",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Tin is a chemical element that is obtained chiefly from the mineral cassiterite, where it occurs as an oxide, SnO2. This silvery, malleable poor metal is not easily oxidized in air, and is used to coat other metals to prevent corrosion. It is used in many alloys, most notably bronze."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Tin"
      },
      "skos:prefLabel": "METAL_TIN",
      "sw:term_status": "testing"
    },
