      "rdfs:label": {
        "@language": "en",
        "@value": "Paper other"
      },
      "skos:prefLabel": "PAPER_OTHER",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-PAPER_PAPER",
