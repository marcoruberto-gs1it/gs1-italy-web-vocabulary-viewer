      "rdfs:comment": {
        "@language": "en",
        "@value": "A non specific material in a lightweight cellular form resulting from introduction of gas bubbles during manufacture, used to reduce shock and vibration or abrasion."
      },
      "rdfs:label": {
        "@language": "en",
