    {
      "@id": "gs1de:CfpMethodologyCode-OTHER",
      "@type": "gs1de:CfpMethodologyCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "A standard calculation method, not classified in the codelist."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Not classified"
      },
      "skos:prefLabel": "OTHER",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:CfpMethodologyCode-ISO_14064",
      "@type": "gs1de:CfpMethodologyCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "ISO 14064 specifies requirements for selecting Greenhouse Gas (GHG) validators/verifiers, establishing the level of assurance, objectives, criteria and scope, determining the validation/verification approach, assessing GHG data, information, information systems and controls, evaluating GHG assertions and preparing validation/verification statements."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "ISO 14064"
      },
      "skos:prefLabel": "ISO_14064",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:CfpMethodologyCode-ENVIMAT",
      "@type": "gs1de:CfpMethodologyCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Value for the product-group from an input-output study, based on ENVIMAT in Finland (Nissinen et al. 2019, SYKEra 15/2019)."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "ENVIMAT"
      },
      "skos:prefLabel": "ENVIMAT",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:CfpMethodologyCode-GHG_PROTOCOL",
      "@type": "gs1de:CfpMethodologyCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "The Product Life Cycle Accounting and Reporting Standard can be used to understand the full life cycle emissions of a product and focus efforts on the greatest Greenhouse Gas (GHG) reduction opportunities."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Greenhouse Gas (GHG) Protocol"
      },
      "skos:prefLabel": "GHG_PROTOCOL",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:CfpMethodologyCode-EPD",
      "@type": "gs1de:CfpMethodologyCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Environmental Product Declaration (EPD)."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "EPD"
      },
      "skos:prefLabel": "EPD",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:CfpAccountingCode",
      "rdfs:label": {
        "@language": "en",
        "@value": "Cfp Accounting Code"
      },
      "rdfs:subClassOf": {
        "@id": "gs1:TypeCode"
      },
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:CfpAccountingCode-ATTRIBUTIONAL",
      "@type": "gs1de:CfpAccountingCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "An attributional life cycle assessment (ALCA) is focusing on describing, assessing and quantifying environmentally relevant physical flows of specific life cycle(s) and its subsystems. An ALCA gives an estimate of what part of the global environmental burdens belongs to the study object. An ALCA does not include environmental benefits or other indirect consequences that arise outside the life cycle of the investigated product."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Attributional"
      },
      "skos:prefLabel": "ATTRIBUTIONAL",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:CfpAccountingCode-CONSEQUENTIAL",
      "@type": "gs1de:CfpAccountingCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "A consequential life cycle assessment (CLCA) is focusing on describing, assessing and quantifying environmentally relevant flows and how they will change in response to possible decisions. A CLCA gives an estimate of how the production and use of the study object affect the global environmental burdens. For example, an increased use of a material in the studied system can lead to less material being used in other systems."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Consequential"
      },
      "skos:prefLabel": "CONSEQUENTIAL",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:PackagingRawMaterialCode",
      "rdfs:label": {
        "@language": "en",
        "@value": "Packaging Raw Material Code"
      },
      "rdfs:subClassOf": {
        "@id": "gs1:TypeCode"
      },
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:PackagingRawMaterialCode-RECYCLED",
      "@type": "gs1de:PackagingRawMaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "The packaging material is made from post consumer recycled content."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Recycled"
      },
      "skos:prefLabel": "RECYCLED",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:PackagingRawMaterialCode-NEW_RAW_MATERIAL_OTHER",
      "@type": "gs1de:PackagingRawMaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "The packaging material is made from new, non-sustainable, materials not listed in the code list."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "New raw material other"
      },
      "skos:prefLabel": "NEW_RAW_MATERIAL_OTHER",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:PackagingRawMaterialCode-BIOLOGICAL_PLASTIC",
      "@type": "gs1de:PackagingRawMaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "The packaging material is made from bio-based/bio-sourced plastics whole or partially from renewable biological resources, like sugar cane, starch."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Bio-based/Bio-sourced plastic"
      },
      "skos:prefLabel": "BIOLOGICAL_PLASTIC",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:PackagingRawMaterialCode-CRUDE_OIL",
      "@type": "gs1de:PackagingRawMaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "The packaging material is made from crude oil."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Crude Oil"
      },
      "skos:prefLabel": "CRUDE_OIL",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode",
      "rdfs:label": {
        "@language": "en",
        "@value": "Material Code"
      },
      "rdfs:subClassOf": {
        "@id": "gs1:TypeCode"
      },
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-PLASTIC_BIO_PLASTIC",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Plastic materials made from biomass, but may have exactly the same properties as ordinary plastic. Sometimes these plastics are biodegradable."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Bioplastic"
      },
      "skos:prefLabel": "PLASTIC_BIO_PLASTIC",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MicroplasticTypeCode",
      "rdfs:label": {
        "@language": "en",
        "@value": "Microplastic Type Code"
      },
      "rdfs:subClassOf": {
        "@id": "gs1:TypeCode"
      },
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MicroplasticTypeCode-PRIMARY_TYPE_A",
      "@type": "gs1de:MicroplasticTypeCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Primary microplastics type A are already produced during the manufacturing of a product. The release of primary microplastics type A can be intentional, knowingly accepted, or caused by an accident. Examples include abrasive particles in cosmetics, polymer blasting media, laser sinter powder for 3D printing, or plastic pellets."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Microplastic Type A"
      },
      "skos:prefLabel": "PRIMARY_TYPE_A",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MicroplasticTypeCode-PRIMARY_TYPE_B",
      "@type": "gs1de:MicroplasticTypeCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Primary microplastics type B are formed during the usage phase. Examples are tire wear, synthetic fibers released during washing, or weathering of paints."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Microplastic Type B"
      },
      "skos:prefLabel": "PRIMARY_TYPE_B",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MicroplasticTypeCode-SECONDARY_MICROPLASTIC",
      "@type": "gs1de:MicroplasticTypeCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Secondary microplastics are formed through the weathering and fragmentation of macroplastics in the environment."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Secondary Microplastic"
      },
      "skos:prefLabel": "SECONDARY_MICROPLASTIC",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode",
      "rdfs:label": {
        "@language": "en",
        "@value": "Material Code"
      },
      "rdfs:subClassOf": {
        "@id": "gs1:TypeCode"
      },
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_ABACA",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Fibre obtained from the sheathing leaf of Musa textilis."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Abaca (Manila hemp)"
      },
      "skos:prefLabel": "FIBRE_ABACA",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_ACRYLIC",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Fibre formed of linear macromolecules comprising at least 85% (by mass) in the chain of the acrylonitrilic pattern."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Acrylic"
      },
      "skos:prefLabel": "FIBRE_ACRYLIC",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_ALFA",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Fibre obtained from the leaves of Stipa tenacissima (esparto, esparto grass, halfah grass, alfa grass, or needle grass)."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Alfa"
      },
      "skos:prefLabel": "FIBRE_ALFA",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_ALGINATE",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Fibre obtained from metallic salts of alginic acid."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Alginate"
      },
      "skos:prefLabel": "FIBRE_ALGINATE",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_WOOL_ALPACA",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Alpaca hair specifically refers to the fur from the body of a alpaca, but more generally refers to the fibre (and cloth)."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Alpaca wool"
      },
      "skos:prefLabel": "FIBRE_WOOL_ALPACA",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_WOOL_ANGORA",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Angora hair or Angora fibre refers to the downy coat produced by the Angora rabbit."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Angora wool"
      },
      "skos:prefLabel": "FIBRE_WOOL_ANGORA",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_ARAMID",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Fibre formed from synthetic linear macromolecules made up of aromatic groups joined by amide or imide linkages, of which at least 85% are joined directly to two aromatic rings and with the number of imide linkages, if present, not exceeding the number of amide linkages."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Aramid"
      },
      "skos:prefLabel": "FIBRE_ARAMID",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-BAMBOO",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Any of various woody or arborescent grasses (as of the genera Bambusa, Arundinaria, and Dendrocalamus of the subfamily Bambusoideae) of tropical and temperate regions having hollow stems, thick rhizomes, and shoots. The packaging may be in the form of paper, wood or leaves."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Bamboo"
      },
      "skos:prefLabel": "BAMBOO",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_BROOM",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Fibre obtained from the base of Cytisus scoparius and/or Spartium Junceum."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Broom fibre"
      },
      "skos:prefLabel": "FIBRE_BROOM",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_WOOL_CAMEL",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Camel hair specifically refers to the fur from the body of a camel, but more generally refers to the fibre (and cloth)."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Camel wool"
      },
      "skos:prefLabel": "FIBRE_WOOL_CAMEL",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_WOOL_CASHMERE",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Wool obtained from cashmere goats, pashmina goats and some other breeds of goat."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Cashmere wool"
      },
      "skos:prefLabel": "FIBRE_WOOL_CASHMERE",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-CELLULOSE_HYDRATE",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "A class of materials manufactured by the conversion of natural cellulose to a soluble cellulosic derivative and subsequent regeneration, typically forming a film (e.g., cellophane)."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Cellulose hydrate"
      },
      "skos:prefLabel": "CELLULOSE_HYDRATE",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-CERAMIC",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "A non-specific material made from clay and hardened by firing at a high temperatures. Examples can include terra-cotta, earthenware, stoneware, porcelain, and high-tech ceramics."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Ceramic"
      },
      "skos:prefLabel": "CERAMIC",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_CHLOROFIBRE",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Fibre formed of linear macromolecules having in their chain more than 50% by mass of chlorinated vinyl or chlorinated vinylidene monomeric units."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Chlorofibre"
      },
      "skos:prefLabel": "FIBRE_CHLOROFIBRE",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-CLOTH_OR_FABRIC",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "A non specific material made by weaving, felting, knitting, or crocheting natural and/or synthetic fibres."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Cloth or fabric"
      },
      "skos:prefLabel": "CLOTH_OR_FABRIC",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_COIR",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Fibre obtained from the fruit of Cocos nucifera."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Coir (coconut)"
      },
      "skos:prefLabel": "FIBRE_COIR",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-COMPOSITE",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "A material that is made from multiple materials."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Composite"
      },
      "skos:prefLabel": "COMPOSITE",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-CORK_NATURAL",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Cork is an impermeable buoyant material, the phellem layer of bark tissue that is harvested for commercial use primarily from Quercus suber (the cork oak)."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Natural cork"
      },
      "skos:prefLabel": "CORK_NATURAL",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-CORRUGATED_BOARD_DOUBLE_WALL",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "A structure formed by two layers of corrugated cardboard (flutes), with a linerboard facing between them."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Double wall corrugated board"
      },
      "skos:prefLabel": "CORRUGATED_BOARD_DOUBLE_WALL",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-CORRUGATED_BOARD_OTHER",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "The value needed is not listed or is not defined within this list's individual code value and definitions of corrugated boards. Please send a work request into GS1 or your solution provider requesting the code you are searching for."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Corrugated board other"
      },
      "skos:prefLabel": "CORRUGATED_BOARD_OTHER",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-CORRUGATED_BOARD_SINGLE_WALL",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "A structure formed by three layers of paper that are glued using starch into one single, sturdy sheet; also termed double faced."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Single wall corrugated board"
      },
      "skos:prefLabel": "CORRUGATED_BOARD_SINGLE_WALL",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-CORRUGATED_BOARD_TRIPLE_WALL",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "A structure formed by an inner and outer liner with three fluted sheets in between, each separated by a layer of paper."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Triple wall corrugated board"
      },
      "skos:prefLabel": "CORRUGATED_BOARD_TRIPLE_WALL",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_CUPRO",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Regenerated cellulose fibre obtained by the cuprammonium process."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Cupro"
      },
      "skos:prefLabel": "FIBRE_CUPRO",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_ELASTANE",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Elastofibre composed of at least 85% (by mass) of a segmented polyurethane, and which, when stretched to three times its original length and released, recovers rapidly and substantially to its initial length."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Elastane"
      },
      "skos:prefLabel": "FIBRE_ELASTANE",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_ELASTODIENE",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Elastofibre composed of natural or synthetic polyisoprene, or composed of one or more dienes polymerised with or without one or more vinyl monomers, and which, when stretched to three times its original length and released, recovers rapidly and substantially to its initial length."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Elastodiene"
      },
      "skos:prefLabel": "FIBRE_ELASTODIENE",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_ELASTOMULTIESTER",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Fibre formed by interaction of two or more chemically distinct linear macromolecules in two or more distinct phases (of which none exceeds 85% by mass) which contains ester groups as the dominant functional unit (at least 85%) and which, after suitable treatment when stretched to one and half times its original length and released, recovers rapidly and substantially to its initial length."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Elastomultiester"
      },
      "skos:prefLabel": "FIBRE_ELASTOMULTIESTER",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_BURLAP",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "The American name for cloth woven from jute plant skins and other vegetable fibres. In other parts of the world it is known as Hessian, Hessian cloth, or gunny from the Indian gain."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Burlap fibre"
      },
