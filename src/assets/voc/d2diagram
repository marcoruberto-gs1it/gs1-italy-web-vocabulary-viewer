gs1de_GreenhouseGasEmissionInformation."🟢 gs1it:actualEmissions" -> gs1it_ActualEmissions: "gs1it:actualEmissions"

# Sviluppo Target
gs1de_TargetEmissions."🟠 gs1de:greenhouseGasEmissionReductionTarget" -> gs1de_GreenhouseGasEmissionReductionTargetDetails: "gs1de:greenhouseGasEmissionReductionTarget"
gs1de_TargetEmissions."🟠 gs1de:greenhouseGasEmissionReductionTargetVerification" -> gs1_ReferencedFileDetails: "gs1de:greenhouseGasEmissionReductionTargetVerification"
gs1de_TargetEmissions."🟠 gs1de:greenhouseGasEmissionInfoIsExternallyValidated" -> gs1: NonbinaryLogicCode: "gs1de:greenhouseGasEmissionInfoIsExternallyValidated"
