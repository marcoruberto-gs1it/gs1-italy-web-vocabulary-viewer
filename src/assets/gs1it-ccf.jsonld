      },
      "skos:prefLabel": "RUBBER_NATURAL",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-OTHER",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "The value needed is not listed or is not defined within this list's individual code values and definitions. Please send a work request into GS1 or your solution provider requesting the code you are searching for."
