      "@id": "gs1de:MaterialCode-FIBRE_OTHER_FROM_ANIMAL",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "The value needed is not listed or is not defined within this list's individual code value and definitions of fibre from animals. Please send a work request into GS1 or your solution provider requesting the code you are searching for."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Other animal fibre"
      },
      "skos:prefLabel": "FIBRE_OTHER_FROM_ANIMAL",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-PAPER_CORRUGATED",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
