gs1de_GreenhouseGasEmissionReductionTargetDetails."🟠 gs1de:greenhouseGasEmissionTarget" -> gs1de_GreenhouseGasEmissionStatement: "gs1de:greenhouseGasEmissionTarget"
gs1de_GreenhouseGasEmissionReductionTargetDetails."🟠 gs1de:greenhouseGasEmissionScope" -> gs1de_GreenhouseGasEmissionScopeType: "gs1de:greenhouseGasEmissionScope"

# Sviluppo Actuals
gs1it_ActualEmissions."🟢 gs1it:consumptionEmissionsScope1And2" -> gs1it_ConsumptionEmissionsScope1And2: "gs1it:consumptionEmissionsScope1And2"
gs1it_ActualEmissions."🟢 gs1it:transportActivityEmissions" -> gs1it_TransportActivityEmissions: "gs1it:transportActivityEmissions"
gs1it_ActualEmissions."🟢 gs1it:wasteEmissions" -> gs1it_WasteEmissions: "gs1it:wasteEmissions"
gs1it_ActualEmissions."🟢 gs1it:waterEmissions" -> gs1it_WaterEmissions: "gs1it:waterEmissions"

# Sviluppo Scope 1 & 2 (Consumi)
gs1it_ConsumptionEmissionsScope1And2."🟢 gs1it:electricityCO2eEmissions" -> gs1it_ElectricityCO2eEmissions: "gs1it:electricityCO2eEmissions"
gs1it_ConsumptionEmissionsScope1And2."🟢 gs1it:fuelCO2eEmissions" -> gs1it_FuelCO2eEmissions: "gs1it:fuelCO2eEmissions"
gs1it_ConsumptionEmissionsScope1And2."🟢 gs1it:refrigerantLeaksCO2eEmissions" -> gs1it_RefrigerantLeaksCO2eEmissions: "gs1it:refrigerantLeaksCO2eEmissions"

# Rete Elettricità
gs1it_ElectricityCO2eEmissions."🟢 gs1it:electricityConsumptionDetails" -> gs1it_ElectricityConsumption: "gs1it:electricityConsumptionDetails"
gs1it_ElectricityConsumption."🟢 gs1it:electricityConsumption" -> gs1_QuantitativeValue: "gs1it:electricityConsumption"
gs1it_ElectricityConsumption."🟢 gs1it:electricityType" -> gs1it_ElectricityTypeCode: "gs1it:electricityType"

# Rete Combustibili
gs1it_FuelCO2eEmissions."🟢 gs1it:fuelConsumptionDetails" -> gs1it_FuelConsumption: "gs1it:fuelConsumptionDetails"
gs1it_FuelConsumption."🟢 gs1it:consumption" -> gs1_QuantitativeValue: "gs1it:consumption"
gs1it_FuelConsumption."🟢 gs1it:fuelType" -> gs1it_FuelTypeCode: "gs1it:fuelType"

# Rete Refrigeranti
gs1it_RefrigerantLeaksCO2eEmissions."🟢 gs1it:refrigerantRecharged" -> gs1it_RefrigerantRecharged: "gs1it:refrigerantRecharged"
gs1it_RefrigerantLeaksCO2eEmissions."🟢 gs1it:refrigerantLost" -> gs1it_RefrigerantLost: "gs1it:refrigerantLost"
gs1it_RefrigerantRecharged."🟢 gs1it:quantityOfRefrigerantRecharged" -> gs1_QuantitativeValue: "gs1it:quantityOfRefrigerantRecharged"
gs1it_RefrigerantRecharged."🟢 gs1it:refrigerantType" -> gs1it_RefrigerantTypeCode: "gs1it:refrigerantType"
gs1it_RefrigerantLost."🟢 gs1it:quantityOfRefrigerantLost" -> gs1_QuantitativeValue: "gs1it:quantityOfRefrigerantLost"
gs1it_RefrigerantLost."🟢 gs1it:refrigerantType" -> gs1it_RefrigerantTypeCode: "gs1it:refrigerantType"

