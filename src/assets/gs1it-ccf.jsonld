        "@language": "en",
        "@value": "Cotton"
      },
      "skos:prefLabel": "FIBRE_COTTON",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_FLAX",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "The plant from the stem of which bast fibre is extracted by retting to produce linen. An erroneous term for linen fibre, particularly in blends."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Flax"
      },
      "skos:prefLabel": "FIBRE_FLAX",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_HEMP",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Hemp is a commonly used term for varieties of the Cannabis plant. Hemp can yield fibre which can be used in ropes, cloths, weaves, as a reinforcement of polymer composites as well as pulps for paper making."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Hemp"
      },
      "skos:prefLabel": "FIBRE_HEMP",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_JUTE",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "A bast fibre obtained from the round pod jute or the long pod jute of the family Tiliaceae. Jute ribbon is purely made from the jute plant. Grown extensively in Pakistan and India, mainly in the Bengal district of Pakistan."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Jute"
      },
      "skos:prefLabel": "FIBRE_JUTE",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_OTHER",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "The value needed is not listed or is not defined within this list's individual code value and definitions of fibre. Please send a work request into GS1 or your solution provider requesting the code you are searching for."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Fibre other"
      },
      "skos:prefLabel": "FIBRE_OTHER",
      "sw:term_status": "testing"
    },
    {
      "@id": "gs1de:MaterialCode-FIBRE_FLUOROFIBRE",
      "@type": "gs1de:MaterialCode",
      "rdfs:comment": {
        "@language": "en",
        "@value": "Fibre formed of linear macromolecules made from fluorocarbon aliphatic monomers."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Fluorofibre"
