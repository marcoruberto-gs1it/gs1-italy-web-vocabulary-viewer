        "@value": "A regenerated cellulose fibre obtained by a modified viscose process having a high breaking force and high wet modulus."
      },
      "rdfs:label": {
        "@language": "en",
        "@value": "Modal"
      },
      "skos:prefLabel": "FIBRE_MODAL",
      "sw:term_status": "testing"
